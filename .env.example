# ------------------------------------------------------------------
# Copy this file to ".env" and fill in your own values.
# We use one OpenAI-compatible client for ALL providers — you only
# swap base_url + model. Works with DeepSeek / Qwen(通义) / Zhipu(智谱)
# / Moonshot(Kimi) / OpenAI, etc.
# ------------------------------------------------------------------

# --- LLM (OpenAI-compatible endpoint) ---
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- Generation settings ---
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.0

# --- Reliability (Phase 5; all optional) ---
# Wall-clock timeout for a single SQL query (seconds); a watchdog interrupts it.
DB_QUERY_TIMEOUT=5
# Fallback model used if the primary call fails. If only FALLBACK_MODEL is set,
# the primary base_url/key are reused; otherwise configure a separate provider.
FALLBACK_MODEL=
FALLBACK_BASE_URL=
FALLBACK_API_KEY=

# --- Observability (Phase 5) ---
# Cost-estimate pricing (USD per 1M tokens); shared by tracing + eval reports.
PRICE_IN_PER_M=0.27
PRICE_OUT_PER_M=1.10
# Local JSONL tracing is ALWAYS on (data/traces/). Optionally also ship to
# Langfuse cloud by filling these in:
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Embeddings (OPTIONAL — only for the semantic schema retriever) ---
# Any OpenAI-compatible embedding endpoint. Leave blank to use the
# zero-dependency lexical retriever (`--schema lexical`). Examples:
#   SiliconFlow: base_url=https://api.siliconflow.cn/v1  model=BAAI/bge-m3
#   DashScope  : base_url=https://dashscope.aliyuncs.com/compatible-mode/v1  model=text-embedding-v3
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_MODEL=

# --- Answer cache (Phase 11a; optional) ---
# Skip the whole pipeline when the SAME first-turn question comes back, for a
# 0-cost instant reply. Exact-match on a normalized question (NOT embedding
# similarity — "top 5" vs "top 10" embed almost identically but must not share
# an answer). The cache key includes the governance role, so roles that see
# different data never share entries. Entries expire after the TTL.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400          # 24h

# --- Feedback flywheel (Phase 11b; optional) ---
# 👍 promotes a (question -> SQL) pair into a verified, same-database few-shot
# example, injected ahead of the Spider pool (the product gets more accurate the
# more it is used). 👎 only logs the miss + invalidates that question's cache —
# it never becomes a positive example. Up to *_FEWSHOT_K verified examples are
# injected per query.
FEEDBACK_ENABLED=true
FEEDBACK_FEWSHOT_K=3

# --- Pinned questions / dashboard (Phase 11c; optional) ---
# Pin a QUESTION (not its answer) into a re-runnable dashboard card, bound to the
# db + governance role that produced it (refreshing re-runs under that role, so a
# viewer card can never refresh into an analyst's unmasked data).
PINS_ENABLED=true

# --- Data governance (Phase 10) ---
# NOTE: governance has NO env vars — it is configured by `policies.yaml` (roles,
# row-level filters, column ACLs) and the `pii:` blocks in `semantics/<id>.yaml`.
# Both are definitions, not secrets, and are committed to git. See README.
